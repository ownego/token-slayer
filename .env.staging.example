# Copy to .env on the home server, fill in secrets, then:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d --build

APP_NAME=token-slayer
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.example.com

# Identifier baked into the hook installer (token dir, env var, codex markers).
# Defaults to a slugified APP_NAME. Must be a valid shell identifier.
# HOOK_NAMESPACE=token_slayer

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Postgres — external service. If it runs on the same host as Docker,
# use DB_HOST=host.docker.internal (mapped via extra_hosts in compose).
DB_CONNECTION=pgsql
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=token_slayer
DB_USERNAME=token_slayer
DB_PASSWORD=change-me

# Database-driven cache, sessions, queues (no Redis required)
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Reverb: server listens inside the `reverb` container on 8080.
# REVERB_HOST/PORT/SCHEME here are the *internal* address PHP uses to
# broadcast (server -> reverb via Docker network), so no public round-trip.
# VITE_REVERB_* are the *public* values the browser uses; the WebSocket is
# routed through the same hostname as the app, under the /app/ path.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=app.example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Host ports the services bind to on 127.0.0.1 (host cloudflared connects here).
# Configure ONE public hostname in the Cloudflare Zero Trust dashboard with
# path-based ingress rules (order matters — most specific first):
#   app.example.com  Path=^/app/   -> http://localhost:${REVERB_HOST_PORT}   (Reverb WebSocket)
#   app.example.com  (no path)     -> http://localhost:${APP_PORT}           (Laravel app)
# A second-level subdomain like ws.app.example.com will NOT work behind
# Cloudflare's free Universal SSL — only one level of wildcard is covered.
APP_PORT=8000
REVERB_HOST_PORT=3011
