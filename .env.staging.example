# Copy to .env on the home server, fill in secrets, then:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d --build

APP_NAME=aiorg
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.example.com

# Identifier baked into the hook installer (token dir, env var, codex markers).
# Defaults to a slugified APP_NAME. Must be a valid shell identifier.
# HOOK_NAMESPACE=aiorg

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# Postgres — external service. If it runs on the same host as Docker,
# use DB_HOST=host.docker.internal (mapped via extra_hosts in compose).
DB_CONNECTION=pgsql
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=aiorg
DB_USERNAME=aiorg
DB_PASSWORD=change-me

# Database-driven cache, sessions, queues (no Redis required)
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Reverb: server listens inside the `reverb` container on 8080.
# REVERB_HOST/PORT/SCHEME are the public-facing values the browser uses
# via Cloudflare Tunnel (e.g., wss://ws.example.com:443).
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=ws.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Host ports the services bind to on 127.0.0.1 (host cloudflared connects here).
# Configure two public hostname routes in the Cloudflare Zero Trust dashboard:
#   app.example.com -> http://localhost:8000
#   ws.example.com  -> http://localhost:8080
APP_PORT=8000
REVERB_PORT=8080
